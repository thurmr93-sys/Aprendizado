algoritmo "Nome do Programa"
var
    num: inteiro
inicio
    escreva("Digite o número: ")
        leia(num)
    se (num > 0) entao
        escreval("Positivo")
     senao
        se (num = 0) entao
            escreva("Número neutro")
         senao
            escreval("Negativo")
        fimse
    fimse

fimalgoritmo