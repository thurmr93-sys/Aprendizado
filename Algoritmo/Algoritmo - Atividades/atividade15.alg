algoritmo "Nome do Programa"
var
    num1: inteiro
    num2: inteiro
inicio
    escreva("Digite o primeiro número: ")
        leia(num1)
    escreva("Digite o segundo número: ")
        leia(num2)
    se (num1 = num2) entao
        escreval("Os números são iguais.")
     senao
        escreval("Os números são distintos.")
    fimse

fimalgoritmo