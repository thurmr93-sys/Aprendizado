algoritmo "Nome do Programa"
var
    num: inteiro
    sucessor: inteiro
    antecessor: inteiro
inicio
    escreva("Digite o número: ")
        leia(num)
    antecessor <- num - 1
    sucessor <- num + 1
    escreval("O antecessor do seu numero é: ", antecessor)
    escreval("O sucessor do seu número é: ", sucessor)

fimalgoritmo